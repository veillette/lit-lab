{
  "name": "lit-lab",
  "version": "1.0.0",
  "description": "LTI 1.3 interactive textbook — launches from Moodle, sends grades back via AGS",
  "main": "server.js",
  "scripts": {
    "build": "eleventy",
    "build:watch": "eleventy --watch",
    "start": "node server.js",
    "dev": "concurrently \"eleventy --watch\" \"nodemon dev-server.js\"",
    "register-platform": "node scripts/register-platform.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ltijs": "^5.9.3"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "concurrently": "^8.2.2",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
