# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ---- LTIJS ----
# Random string, minimum 32 characters. Use: openssl rand -hex 32
LTI_KEY=replace_with_a_long_random_secret_key

# ---- MongoDB Atlas ----
# Create a free M0 cluster at https://cloud.mongodb.com
# Connection string format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/litlab

# ---- Server ----
PORT=3000
NODE_ENV=development   # set to "production" on Cloud Run

# ---- Platform registration (used by scripts/register-platform.js only) ----
MOODLE_URL=https://moodle.example.com
MOODLE_CLIENT_ID=your_client_id_from_moodle
